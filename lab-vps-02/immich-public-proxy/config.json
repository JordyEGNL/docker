{
   "ipp":{
      "responseHeaders":{
         "Cache-Control":"public, max-age=86400"
      },
      "allowDownload": 1,
      "downloadOriginalPhoto":true,
      "maxZoomQuality": "fullsize",
      "gallery":{
         "showTitle":true,
         "groupByDate":true
      },
      "lightbox":{
         "showDownload":true
      },
      "showMetadata":{
         "description":{
            "caption":false,
            "sidebar":true
         },
         "exif":{
            "dateTimeOriginal":true,
            "make":true,
            "model":true,
            "lensModel":true,
            "exposureTime":true,
            "iso":true,
            "fNumber":true,
            "focalLength":true,
            "dimensions": true,
            "fileSize": true
         },
         "location":{
            "city":true,
            "state":true,
            "country":true,
            "gps": true
         }
      }
   }
}
